# Optional local development environment.
#
# Copy this file to .env if you need local-only overrides. Do not commit .env or
# real secrets.

# LangSmith tracing for local development.
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=jingle-dev
# LANGSMITH_TRACING=true

# Optional local data directory overrides for isolated development.
# JINGLE_HOME=/tmp/jingle-dev-home
# JINGLE_CONFIG_HOME=/tmp/jingle-dev-config
# JINGLE_DATA_HOME=/tmp/jingle-dev-data

# Web search tooling. Prefer app settings for provider/model credentials.
# TAVILY_API_KEY=
