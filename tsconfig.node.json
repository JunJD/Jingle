{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "src/extensions/index.ts",
    "src/extensions/*/index.ts",
    "src/extensions/*/main/**/*.ts",
    "src/extensions/*/manifest.ts",
    "src/main/**/*",
    "src/plugins/**/*",
    "src/preload/**/*",
    "src/shared/**/*",
    "src/types.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@extensions/*": [
        "src/extensions/*"
      ],
      "@launcher/*": [
        "src/renderer/src/launcher/*"
      ],
      "@plugins/*": [
        "src/plugins/*"
      ],
      "@shared/*": [
        "src/shared/*"
      ]
    },
    "types": [
      "electron-vite/node"
    ]
  }
}
