{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "extensions/**/*",
    "src/extensions/**/*",
    "src/extension-runtime/**/*",
    "src/main/**/*",
    "packages/*/src/**/*",
    "src/plugins/**/*",
    "src/preload/**/*",
    "src/shared/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "tsBuildInfoFile": "node_modules/.cache/tsconfig.node.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/renderer/src/*"
      ],
      "@ai-core/*": [
        "src/renderer/src/ai-core/*"
      ],
      "@extension-host/*": [
        "src/renderer/src/extension-host/*"
      ],
      "@extensions/*": [
        "src/extensions/*"
      ],
      "@launcher-components/*": [
        "src/renderer/src/launcher-components/*"
      ],
      "@launcher-shell/*": [
        "src/renderer/src/launcher-shell/*"
      ],
      "@openwork/extension-api": [
        "packages/extension-api/src/index.ts"
      ],
      "@openwork/extension-api/host-runtime": [
        "packages/extension-api/src/host-runtime.ts"
      ],
      "@openwork/agent-runtime": [
        "packages/agent-runtime/src/index.ts"
      ],
      "@openwork/extension-utils": [
        "packages/extension-utils/src/index.ts"
      ],
      "@plugins/*": [
        "src/plugins/*"
      ],
      "@renderer/*": [
        "src/renderer/src/*"
      ],
      "@shared/*": [
        "src/shared/*"
      ]
    },
    "types": [
      "electron-vite/node"
    ]
  }
}
