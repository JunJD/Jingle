{
  "cSpell.words": [
    "agentcore",
    "AGUI",
    "asar",
    "checkpointer",
    "checkpointers",
    "checkpointing",
    "configurate",
    "dashscope",
    "dedupe",
    "deepagents",
    "deepagentsjs",
    "dingjunjie",
    "fkey",
    "HITL",
    "junjieding",
    "kwargs",
    "langchain",
    "Langgraph",
    "linkedom",
    "minimizable",
    "notionhq",
    "osascript",
    "Prefs",
    "Pregel",
    "quicklink",
    "quicklinks",
    "refreshable",
    "REMCD",
    "reminderkit",
    "Renderable",
    "serde",
    "shiki",
    "Tavily",
    "tryfabric",
    "tsyringe",
    "unins",
    "upserted",
    "virtua"
  ],
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "git.ignoreLimitWarning": true
}
